# ── YOUR IDENTITY ──────────────────────────────────────────────────────
# What should the AI be called? This appears in the UI header.
# Example: YOUR_NAME=Ava  →  header shows "ASK AVA"
YOUR_NAME=Isaac

# Optional: Override the default system prompt entirely.
# Leave blank to use the built-in persona prompt.
CUSTOM_SYSTEM_PROMPT=

# ── GOOGLE CLOUD (GEMINI API) ──────────────────────────────────────────
# Your GCP project ID. Find it at console.cloud.google.com
GCP_PROJECT_ID=your-gcp-project-id

# The region to use for Vertex AI. us-central1 is recommended.
GCP_LOCATION=us-central1

# ── SUPABASE ───────────────────────────────────────────────────────────
# Your Supabase project URL. Found in Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase secret key. Found in Project Settings → API Keys.
# Use the "secret" key, NOT the publishable/anon key.
SUPABASE_SERVICE_KEY=your-supabase-secret-key
